    {
      "parameters": {
        "sendTo": "={{ $json.email_contacto }}",
        "subject": "={{ $json.asunto_email }}",
        "emailType": "html",
        "message": "=<html lang='es'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1.0'></head><body style='margin:0;padding:20px;background:#f4f6f9;font-family:Arial,sans-serif;'><div style='max-width:600px;margin:0 auto;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 16px rgba(0,0,0,.10);'><div style='background:linear-gradient(135deg,#1a73e8,#0d47a1);padding:28px 36px;'><h1 style='margin:0;color:#ffffff;font-size:21px;font-weight:700;'>AndCode</h1><p style='margin:5px 0 0;color:rgba(255,255,255,.8);font-size:13px;'>Desarrollo Web · Aplicaciones · Automatización</p></div><div style='padding:36px;'><p style='font-size:16px;color:#2c3e50;margin:0 0 22px;'>Hola <strong>{{ $json.nombre_contacto }}</strong>,</p><div style='background:#fffbeb;border-left:4px solid #f59e0b;border-radius:6px;padding:18px;margin-bottom:22px;'><p style='margin:0;color:#555;font-size:15px;line-height:1.75;'>{{ $json.problema }}</p></div><p style='color:#444;font-size:15px;line-height:1.75;margin:0 0 22px;'>{{ $json.propuesta }}</p><div style='background:#eff6ff;border-radius:8px;padding:22px;'><p style='margin:0;color:#1d4ed8;font-size:15px;font-weight:500;line-height:1.65;'>{{ $json.cta }}</p></div></div><div style='background:#f9fafb;padding:22px 36px;border-top:1px solid #e5e7eb;'><p style='margin:0;font-size:14px;color:#6b7280;'>Un saludo,</p><p style='margin:5px 0 2px;font-size:15px;font-weight:700;color:#111827;'>Equipo AndCode</p><p style='margin:0;font-size:13px;color:#9ca3af;'>www.andcode.es</p></div></div><p style='text-align:center;font-size:11px;color:#9ca3af;margin-top:15px;'>Si no deseas recibir más comunicaciones, responde indicándolo.</p></body></html>",
        "options": {
          "senderName": "AndCode"
        }
      },
